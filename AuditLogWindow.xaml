<Window x:Class="IndustrialVisionHost.AuditLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="操作审计"
        Width="1200" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#CBD5E1"
                BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="开始日期" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <DatePicker x:Name="StartDatePicker" Width="135" Height="32" Margin="0,0,12,0"/>
                <TextBlock Text="结束日期" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <DatePicker x:Name="EndDatePicker" Width="135" Height="32" Margin="0,0,12,0"/>
                <TextBlock Text="用户名" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="UsernameFilterInput" Width="120" Height="32"
                         Padding="7,4" Margin="0,0,12,0" ToolTip="留空查询全部用户"/>
                <TextBlock Text="动作类型" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="ActionFilterInput" Width="160" Height="32"
                         Padding="7,4" Margin="0,0,12,0" ToolTip="例如 Login、SaveRecipe；留空查询全部"/>
                <Button Content="查询/刷新" Width="105" Height="32" Click="Query_Click"/>
            </WrapPanel>
        </Border>

        <DataGrid x:Name="AuditGrid" Grid.Row="1"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" SelectionMode="Single"
                  BorderBrush="#CBD5E1" BorderThickness="1"
                  AlternatingRowBackground="#F8FAFC"
                  RowHeight="30" FontSize="13"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="65"/>
                <DataGridTextColumn Header="时间" Binding="{Binding OccurredAtLocalText}" Width="170"/>
                <DataGridTextColumn Header="用户" Binding="{Binding UserText}" Width="180"/>
                <DataGridTextColumn Header="角色" Binding="{Binding Role}" Width="105"/>
                <DataGridTextColumn Header="动作" Binding="{Binding ActionType}" Width="150"/>
                <DataGridTextColumn Header="目标类型" Binding="{Binding TargetType}" Width="125"/>
                <DataGridTextColumn Header="目标" Binding="{Binding TargetIdentifier}" Width="180"/>
                <DataGridTextColumn Header="结果" Binding="{Binding OutcomeText}" Width="70"/>
                <DataGridTextColumn Header="详情" Binding="{Binding Details}" Width="300"/>
                <DataGridTextColumn Header="工作站" Binding="{Binding Workstation}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock x:Name="StatusTextBlock" Grid.Row="2"
                   Margin="0,8,0,0" Foreground="#475569"/>
    </Grid>
</Window>
