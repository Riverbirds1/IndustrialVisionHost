<Window x:Class="IndustrialVisionHost.AlarmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="报警记录 - 工业视觉检测上位机"
        Width="1200"
        Height="700"
        MinWidth="900"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        Background="#F3F4F6">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="14" Background="White"
                BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="6">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="开始日期" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker x:Name="StartDatePicker" Width="140" Margin="0,0,14,0"/>
                <TextBlock Text="结束日期" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker x:Name="EndDatePicker" Width="140" Margin="0,0,14,0"/>
                <CheckBox x:Name="ActiveOnlyCheckBox" Content="仅显示活动报警"
                          IsChecked="True" VerticalAlignment="Center" Margin="0,0,18,0"/>
                <Button Content="查询 / 刷新" Width="120" Height="36"
                        Click="Refresh_Click" Margin="0,0,10,0"/>
                <Button x:Name="AcknowledgeButton" Content="确认选中报警"
                        Width="140" Height="36" Click="Acknowledge_Click"/>
            </WrapPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,10,0,10" Padding="12,8"
                Background="#FFF7ED" BorderBrush="#FDBA74"
                BorderThickness="1" CornerRadius="5">
            <TextBlock x:Name="StatusTextBlock" TextWrapping="Wrap"
                       Foreground="#9A3412" FontWeight="SemiBold"/>
        </Border>

        <DataGrid Grid.Row="2" x:Name="AlarmDataGrid"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionUnit="FullRow"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn Header="状态" Binding="{Binding StatusText}" Width="125"/>
                <DataGridTextColumn Header="级别" Binding="{Binding SeverityText}" Width="70"/>
                <DataGridTextColumn Header="报警代码" Binding="{Binding AlarmCode}" Width="180"/>
                <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="130"/>
                <DataGridTextColumn Header="消息" Binding="{Binding Message}" Width="300"/>
                <DataGridTextColumn Header="次数" Binding="{Binding OccurrenceCount}" Width="60"/>
                <DataGridTextColumn Header="首次发生" Binding="{Binding RaisedAtLocalText}" Width="145"/>
                <DataGridTextColumn Header="最近发生" Binding="{Binding LastOccurredAtLocalText}" Width="145"/>
                <DataGridTextColumn Header="确认人" Binding="{Binding AcknowledgedBy}" Width="90"/>
                <DataGridTextColumn Header="确认时间" Binding="{Binding AcknowledgedAtLocalText}" Width="145"/>
                <DataGridTextColumn Header="恢复时间" Binding="{Binding ClearedAtLocalText}" Width="145"/>
                <DataGridTextColumn Header="恢复原因" Binding="{Binding ClearReason}" Width="240"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" Margin="0,10,0,0" Foreground="#4B5563"
                   Text="说明：确认表示人员已经看到并处理；报警必须在故障条件真正消失后，才由系统恢复清除。"/>
    </Grid>
</Window>
