<Window x:Class="IndustrialVisionHost.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="登录 - 工业视觉检测上位机"
        Width="480" Height="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F1F5F9">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="14">
        <Border Background="White" BorderBrush="#CBD5E1"
                BorderThickness="1" CornerRadius="10" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="工业视觉检测上位机"
                           FontSize="22" FontWeight="Bold" Foreground="#0F172A"
                           HorizontalAlignment="Center"/>
                <TextBlock Grid.Row="1" Text="请输入本地账户后进入系统"
                           FontSize="14" Foreground="#64748B"
                           HorizontalAlignment="Center" Margin="0,4,0,14"/>
                <StackPanel Grid.Row="2">
                    <TextBlock Text="用户名" FontSize="14" Margin="0,0,0,6"/>
                    <TextBox x:Name="UsernameTextBox" Text="operator"
                             Height="34" MaxLength="50" Padding="9,5" FontSize="15"/>
                </StackPanel>
                <StackPanel Grid.Row="3" Margin="0,9,0,0">
                    <TextBlock Text="密码" FontSize="14" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PasswordInput" Height="34"
                                 MaxLength="128" Padding="9,5" FontSize="15"/>
                </StackPanel>
                <TextBlock x:Name="ErrorTextBlock" Grid.Row="4"
                           Foreground="#DC2626" TextWrapping="Wrap"
                           MinHeight="18" Margin="0,6,0,0"/>
                <StackPanel Grid.Row="5" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="0,5,0,10">
                    <Button Content="登录" Width="120" Height="34"
                            Margin="0,0,12,0" IsDefault="True"
                            Click="Login_Click" Background="#2563EB"
                            Foreground="White" FontWeight="SemiBold"/>
                    <Button Content="退出" Width="100" Height="34"
                            IsCancel="True" Click="Cancel_Click"/>
                </StackPanel>
                <Border Grid.Row="6" Background="#EFF6FF" BorderBrush="#BFDBFE"
                        BorderThickness="1" CornerRadius="5" Padding="9">
                    <StackPanel>
                        <TextBlock Text="首次运行演示账户" FontWeight="SemiBold"
                                   Foreground="#1E3A8A" Margin="0,0,0,3"/>
                        <TextBlock Text="操作员：operator / Operator@123&#x0a;工程师：engineer / Engineer@123&#x0a;管理员：admin / Admin@123"
                                   FontFamily="Consolas" FontSize="12.5"
                                   Foreground="#1E40AF" LineHeight="17"/>
                        <TextBlock x:Name="InitializationTextBlock" Foreground="#92400E"
                                   FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
    </ScrollViewer>
</Window>
