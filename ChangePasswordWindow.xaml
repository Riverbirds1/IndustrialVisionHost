<Window x:Class="IndustrialVisionHost.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="修改密码"
        Width="470" Height="540"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#F1F5F9">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="18">
            <Border Background="White" BorderBrush="#CBD5E1"
                    BorderThickness="1" CornerRadius="8" Padding="22">
                <StackPanel>
                    <TextBlock Text="修改账户密码"
                               FontSize="23" FontWeight="Bold"
                               Foreground="#0F172A"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="InstructionTextBlock"
                               Foreground="#475569" TextWrapping="Wrap"
                               TextAlignment="Center" Margin="0,7,0,18"/>

                    <Border Background="#EFF6FF" CornerRadius="4"
                            Padding="10,7" Margin="0,0,0,14">
                        <TextBlock x:Name="UserTextBlock"
                                   Foreground="#1E40AF"
                                   FontWeight="SemiBold"/>
                    </Border>

                    <TextBlock Text="当前密码" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="CurrentPasswordInput"
                                 Height="36" MaxLength="128" Padding="9,6"/>

                    <TextBlock Text="新密码" Margin="0,12,0,5"/>
                    <PasswordBox x:Name="NewPasswordInput"
                                 Height="36" MaxLength="128" Padding="9,6"/>

                    <TextBlock Text="确认新密码" Margin="0,12,0,5"/>
                    <PasswordBox x:Name="ConfirmPasswordInput"
                                 Height="36" MaxLength="128" Padding="9,6"/>

                    <TextBlock Text="至少10个字符，并同时包含大写字母、小写字母、数字和特殊字符。"
                               Foreground="#64748B" FontSize="12"
                               TextWrapping="Wrap" Margin="0,7,0,0"/>

                    <TextBlock x:Name="ErrorTextBlock"
                               Foreground="#DC2626" TextWrapping="Wrap"
                               MinHeight="22" Margin="0,8,0,0"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,8,0,0">
                        <Button Content="确认修改" Width="120" Height="36"
                                IsDefault="True" Click="Confirm_Click"
                                Background="#2563EB" Foreground="White"
                                FontWeight="SemiBold" Margin="0,0,12,0"/>
                        <Button x:Name="CancelButton" Content="取消"
                                Width="100" Height="36" IsCancel="True"
                                Click="Cancel_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
