<Window x:Class="IndustrialVisionHost.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="用户管理"
        Width="1050" Height="680"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        Background="#F1F5F9">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#CBD5E1"
                BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="管理员用户维护" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Text="创建账户、调整启用状态或重置临时密码。所有新密码都要求用户下次登录修改。"
                               Foreground="#64748B" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Content="刷新列表" Width="100" Height="34"
                        Click="Refresh_Click" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <DataGrid x:Name="UsersGrid" Grid.Row="1"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" SelectionMode="Single"
                  BorderBrush="#CBD5E1" BorderThickness="1"
                  AlternatingRowBackground="#F8FAFC"
                  RowHeight="31" FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="用户名" Binding="{Binding Username}" Width="130"/>
                <DataGridTextColumn Header="显示名称" Binding="{Binding DisplayName}" Width="150"/>
                <DataGridTextColumn Header="角色" Binding="{Binding RoleText}" Width="90"/>
                <DataGridTextColumn Header="状态" Binding="{Binding EnabledText}" Width="75"/>
                <DataGridTextColumn Header="密码状态" Binding="{Binding PasswordStatusText}" Width="100"/>
                <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAtLocalText}" Width="145"/>
                <DataGridTextColumn Header="最后登录" Binding="{Binding LastLoginAtLocalText}" Width="145"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#CBD5E1"
                    BorderThickness="1" CornerRadius="6" Padding="14">
                <StackPanel>
                    <TextBlock Text="创建新用户" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,9"/>
                    <WrapPanel>
                        <StackPanel Width="145" Margin="0,0,8,8">
                            <TextBlock Text="用户名" Margin="0,0,0,4"/>
                            <TextBox x:Name="NewUsernameInput" Height="32" MaxLength="50" Padding="7,4"/>
                        </StackPanel>
                        <StackPanel Width="145" Margin="0,0,8,8">
                            <TextBlock Text="显示名称" Margin="0,0,0,4"/>
                            <TextBox x:Name="NewDisplayNameInput" Height="32" MaxLength="50" Padding="7,4"/>
                        </StackPanel>
                        <StackPanel Width="120" Margin="0,0,8,8">
                            <TextBlock Text="角色" Margin="0,0,0,4"/>
                            <ComboBox x:Name="NewRoleCombo" Height="32"
                                      DisplayMemberPath="Value" SelectedValuePath="Key"/>
                        </StackPanel>
                    </WrapPanel>
                    <WrapPanel>
                        <StackPanel Width="298" Margin="0,0,8,0">
                            <TextBlock Text="初始密码" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="NewPasswordInput" Height="32" MaxLength="128" Padding="7,4"/>
                        </StackPanel>
                        <Button Content="创建用户" Width="110" Height="32"
                                VerticalAlignment="Bottom" Click="CreateUser_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="White" BorderBrush="#CBD5E1"
                    BorderThickness="1" CornerRadius="6" Padding="14">
                <StackPanel>
                    <TextBlock Text="选中用户操作" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,9"/>
                    <WrapPanel Margin="0,0,0,9">
                        <Button Content="启用账户" Width="100" Height="32" Margin="0,0,8,0"
                                Click="EnableUser_Click"/>
                        <Button Content="禁用账户" Width="100" Height="32"
                                Click="DisableUser_Click"/>
                    </WrapPanel>
                    <TextBlock Text="临时密码（重置后要求下次登录修改）" Margin="0,0,0,4"/>
                    <WrapPanel>
                        <PasswordBox x:Name="ResetPasswordInput" Width="285" Height="32"
                                     MaxLength="128" Padding="7,4" Margin="0,0,8,0"/>
                        <Button Content="重置密码" Width="100" Height="32"
                                Click="ResetPassword_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock x:Name="StatusTextBlock" Grid.Row="3"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,0" Foreground="#DC2626"/>
    </Grid>
</Window>
