<Application x:Class="IndustrialVisionHost.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:IndustrialVisionHost"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F3F4F6"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SubtleSurfaceBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="AppBorderBrush" Color="#D1D5DB"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111827"/>
    </Application.Resources>
</Application>
